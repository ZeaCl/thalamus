# Thalamus OAuth2 Configuration
# Copy this file to .env.local and fill in your values

# Your Thalamus OAuth2 client credentials
# Get these from your Thalamus dashboard or admin
THALAMUS_CLIENT_ID=your_client_id_here
THALAMUS_CLIENT_SECRET=your_client_secret_here

# The base URL of your Thalamus instance
# For local development: http://localhost:4000
# For production: https://your-thalamus-domain.com
THALAMUS_BASE_URL=http://localhost:4000

# The URL where this Next.js app is running
# For local development: http://localhost:3000
# For production: https://your-app-domain.com
NEXTAUTH_URL=http://localhost:3000
