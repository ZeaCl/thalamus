# Thalamus Server Configuration
THALAMUS_BASE_URL=http://localhost:4000
THALAMUS_ADMIN_EMAIL=admin@example.com
THALAMUS_ADMIN_PASSWORD=admin123

# Test OAuth2 Client Credentials
# Create these clients in Thalamus before running tests
REACT_SPA_CLIENT_ID=test_react_spa_client
REACT_SPA_REDIRECT_URI=http://localhost:5173/callback

NODEJS_CLIENT_ID=test_nodejs_client
NODEJS_CLIENT_SECRET=test_nodejs_secret

PYTHON_CLIENT_ID=test_python_client
PYTHON_CLIENT_SECRET=test_python_secret

# Example Application Ports
REACT_SPA_PORT=5173
NODEJS_PORT=3000
FASTAPI_PORT=8000

# Test User Credentials (create in Thalamus)
TEST_USER_EMAIL=testuser@example.com
TEST_USER_PASSWORD=testpass123
