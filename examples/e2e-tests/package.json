{
  "name": "thalamus-examples-e2e-tests",
  "version": "1.0.0",
  "type": "module",
  "description": "End-to-end tests for Thalamus examples",
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "test:react-spa": "playwright test --grep @react-spa",
    "test:nodejs": "playwright test --grep @nodejs",
    "test:fastapi": "playwright test --grep @fastapi",
    "report": "playwright show-report",
    "install": "playwright install --with-deps chromium"
  },
  "devDependencies": {
    "@playwright/test": "^1.41.1",
    "dotenv": "^16.4.5"
  },
  "dependencies": {
    "axios": "^1.6.7"
  }
}
