{
  "name": "@zeacl/auth",
  "version": "0.1.3",
  "description": "ZEA Thalamus React Auth SDK — OAuth2 PKCE login, user/org management, API keys for React apps",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./components": {
      "types": "./dist/components/index.d.ts",
      "import": "./dist/components/index.mjs"
    },
    "./hooks": {
      "types": "./dist/hooks/index.d.ts",
      "import": "./dist/hooks/index.mjs"
    },
    "./styles/base.css": "./dist/styles/base.css"
  },
  "files": [
    "dist",
    "bin"
  ],
  "bin": {
    "zea-auth-init": "./bin/zea-auth-init.mjs"
  },
  "keywords": [
    "oauth2",
    "auth",
    "thalamus",
    "react",
    "pkce",
    "sso"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "postinstall": "echo '' && echo '🧠  ZEA Auth SDK installed!' && echo '   Run: npx zea-auth-init to set up your app variables' && echo ''",
    "typecheck": "tsc --noEmit",
    "test:unit": "vitest run",
    "coverage": "vitest run --coverage"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.9.3",
    "@types/react": "^19.0.0",
    "@vitest/coverage-v8": "^4.1.9",
    "jsdom": "^29.1.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.1.9"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ZeaCl/thalamus.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  }
}
