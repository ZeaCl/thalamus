{
  "name": "@zea/thalamus-sdk",
  "version": "0.1.0",
  "description": "ZEA Thalamus SDK — OAuth2 PKCE login, user/agent/org management, API keys for React apps",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./components": {
      "types": "./dist/components/index.d.ts",
      "import": "./dist/components/index.mjs"
    },
    "./hooks": {
      "types": "./dist/hooks/index.d.ts",
      "import": "./dist/hooks/index.mjs"
    },
    "./styles/base.css": "./dist/styles/base.css"
  },
  "files": ["dist", "bin"],
  "bin": {
    "thalamus-init": "./bin/thalamus-init.mjs"
  },
  "keywords": ["oauth2", "auth", "thalamus", "react", "pkce", "sso"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "postinstall": "echo '' && echo '🧠  ZEA Thalamus SDK installed!' && echo '   Run: npx thalamus-init to set up your app' && echo ''",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "license": "MIT",
  "repository": "github.com/zeacl/thalamus"
}
