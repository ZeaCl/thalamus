# ============================================================================
# ZEA Thalamus - Environment Variables
# ============================================================================
# Copy this file to .env and fill in your values
# NEVER commit .env to git (it's in .gitignore)

# ----------------------------------------------------------------------------
# Database Configuration
# ----------------------------------------------------------------------------
DATABASE_URL=ecto://postgres:postgres@localhost/thalamus_dev
DB_POOL_SIZE=10

# Test Database
TEST_DATABASE_URL=ecto://postgres:postgres@localhost/thalamus_test

# ----------------------------------------------------------------------------
# Phoenix Server Configuration
# ----------------------------------------------------------------------------
PHX_HOST=localhost
PORT=4000
SECRET_KEY_BASE=your-secret-key-base-min-64-chars-generate-with-mix-phx-gen-secret

# ----------------------------------------------------------------------------
# Redis Configuration (optional, for distributed caching)
# ----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=

# ----------------------------------------------------------------------------
# Email Configuration (optional, for verification emails)
# ----------------------------------------------------------------------------
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USERNAME=apikey
SMTP_PASSWORD=your-sendgrid-api-key
FROM_EMAIL=noreply@thalamus.zea.cl

# ----------------------------------------------------------------------------
# Deployment & Infrastructure
# ----------------------------------------------------------------------------
# DigitalOcean API Token (for deployment automation)
# Get from: https://cloud.digitalocean.com/account/api/tokens
DIGITALOCEAN_TOKEN=your-digitalocean-token-here

# VPS Configuration
VPS_IP=your-vps-ip-here
VPS_USER=root
SSH_KEY_PATH=~/.ssh/id_rsa
DOMAIN=auth.zea.cl

# ----------------------------------------------------------------------------
# OAuth2 Configuration
# ----------------------------------------------------------------------------
# Default OAuth2 scopes
DEFAULT_SCOPES=openid,profile,email

# Token expiration times (in seconds)
ACCESS_TOKEN_TTL=3600
REFRESH_TOKEN_TTL=2592000
AUTHORIZATION_CODE_TTL=600

# ----------------------------------------------------------------------------
# Security & Rate Limiting
# ----------------------------------------------------------------------------
# CORS allowed origins (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://app.zea.cl

# Rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX_REQUESTS=1000
RATE_LIMIT_WINDOW_MS=60000

# ----------------------------------------------------------------------------
# Monitoring & Observability (optional)
# ----------------------------------------------------------------------------
# Sentry DSN for error tracking
SENTRY_DSN=

# Application Insights key
APPINSIGHTS_INSTRUMENTATION_KEY=

# ----------------------------------------------------------------------------
# Feature Flags
# ----------------------------------------------------------------------------
ENABLE_REGISTRATION=true
ENABLE_MFA=true
ENABLE_AGENT_TOKENS=true
