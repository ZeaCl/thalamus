<!DOCTYPE html>
<html lang="en" data-theme="dark" class="h-full bg-base-300">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <title>Sign In · ZEA</title>

    <%!-- Google Sans font --%>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Google+Sans:wght@400;500;700&display=swap"
      rel="stylesheet"
    />

    <link phx-track-static rel="stylesheet" href={~p"/assets/css/app.css"} />
    <script defer phx-track-static type="text/javascript" src={~p"/assets/js/app.js"}>
    </script>

    <style>
      body {
        font-family: 'Google Sans', sans-serif;
      }
    </style>
  </head>
  <body class="h-full antialiased bg-[#0B0D13]">
    <div class="min-h-screen w-full flex flex-col items-center justify-center p-4 relative overflow-hidden">
      <%!-- Background Ambient Glows --%>
      <div class="absolute top-[-10%] left-[-10%] w-[50%] h-[50%] bg-primary/10 rounded-full blur-[120px] pointer-events-none">
      </div>
      <div class="absolute bottom-[-10%] right-[-10%] w-[50%] h-[50%] bg-purple-500/10 rounded-full blur-[120px] pointer-events-none">
      </div>

      <% home_url =
        if String.contains?(@conn.host, "localhost"),
          do: "http://zea.localhost",
          else: "https://zea.cl" %>

      <div class="w-full max-w-md relative z-10 flex flex-col items-center">
        <%!-- Logo and Header --%>
        <div class="flex flex-col items-center mb-8 w-full text-center">
          <div class="flex items-center justify-center gap-2 mb-4">
            <img
              src={~p"/images/icono-zea.svg"}
              alt="ZEA Icon"
              class="h-6 w-6"
              style="filter: brightness(0) invert(1) brightness(0.675);"
            />
            <img
              src={~p"/images/text-zea.svg"}
              alt="ZEA Text"
              class="h-4.5 w-auto"
              style="filter: brightness(0) invert(1) brightness(0.675);"
            />
          </div>
          <h2 class="text-xl font-bold tracking-tight text-white mt-1">
            {gettext("Access your account")}
          </h2>
          <p class="text-xs text-base-content/40 mt-1.5 max-w-[280px]">
            {gettext("Generate API keys, manage credentials and monitor your autonomous agents.")}
          </p>
        </div>

        <%!-- Card container with glassmorphic styles --%>
        <div class="bg-base-100/40 backdrop-blur-xl border border-white/5 shadow-2xl rounded-2xl p-8 relative overflow-hidden w-full">
          <%!-- Subtle top border glow --%>
          <div class="absolute inset-x-0 top-0 h-[1px] bg-gradient-to-r from-transparent via-primary/30 to-transparent">
          </div>

          <%= if @flash["error"] do %>
            <div class="alert alert-error/15 border border-error/20 rounded-xl px-4 py-3 text-xs text-error mb-6 flex items-center gap-2">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="stroke-current shrink-0 h-4.5 w-4.5"
                fill="none"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z"
                />
              </svg>
              <span>{@flash["error"]}</span>
            </div>
          <% end %>

          <.form for={%{}} as={:session} action={~p"/login"} method="post" class="space-y-4">
            <div class="form-control w-full">
              <label class="label py-1">
                <span class="label-text text-[11px] font-medium text-base-content/60 tracking-wide uppercase">
                  {gettext("Email Address")}
                </span>
              </label>
              <input
                type="email"
                name="session[email]"
                class="input bg-base-300/40 border border-white/5 rounded-xl w-full text-sm text-white placeholder-base-content/25 focus:border-primary/50 focus:bg-base-300/60 focus:ring-1 focus:ring-primary/20 transition-all duration-200"
                placeholder="developer@zea.cl"
                required
                autofocus
              />
            </div>

            <div class="form-control w-full">
              <label class="label py-1">
                <span class="label-text text-[11px] font-medium text-base-content/60 tracking-wide uppercase">
                  {gettext("Password")}
                </span>
              </label>
              <input
                type="password"
                name="session[password]"
                class="input bg-base-300/40 border border-white/5 rounded-xl w-full text-sm text-white placeholder-base-content/25 focus:border-primary/50 focus:bg-base-300/60 focus:ring-1 focus:ring-primary/20 transition-all duration-200"
                placeholder="••••••••••••"
                required
              />
            </div>

            <div class="form-control pt-4">
              <button
                type="submit"
                class="btn btn-primary rounded-xl w-full font-medium text-xs tracking-wider uppercase normal-case shadow-lg shadow-primary/20 hover:shadow-primary/30 transition-all duration-200 flex items-center justify-center gap-2"
              >
                <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2.5"
                    d="M11 16l-4-4m0 0l4-4m-4 4h14m-5 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h7a3 3 0 013 3v1"
                  />
                </svg>
                {gettext("Sign In")}
              </button>
            </div>
          </.form>

          <%!-- Social Sign In --%>
          <div class="divider border-white/5 my-5 text-[10px] uppercase font-semibold text-base-content/20 tracking-wider">
            OR SIGN IN WITH
          </div>

          <div class="grid grid-cols-2 gap-3 mb-5">
            <a
              href="/auth/mock/github"
              class="btn bg-base-300/40 hover:bg-base-300/80 border border-white/5 hover:border-white/10 rounded-xl text-white font-medium text-xs normal-case flex items-center justify-center gap-2 transition-all duration-200"
            >
              <svg class="h-4 w-4 fill-current" viewBox="0 0 24 24">
                <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12" />
              </svg>
              GitHub
            </a>
            <a
              href="/auth/mock/google"
              class="btn bg-base-300/40 hover:bg-base-300/80 border border-white/5 hover:border-white/10 rounded-xl text-white font-medium text-xs normal-case flex items-center justify-center gap-2 transition-all duration-200"
            >
              <svg class="h-3.5 w-3.5 fill-current" viewBox="0 0 24 24">
                <path d="M12.24 10.285V14.4h6.887c-.648 2.41-2.519 4.113-5.136 4.113-3.41 0-6.19-2.766-6.19-6.177 0-3.41 2.78-6.177 6.19-6.177 1.545 0 2.94.576 4.01 1.517l3.123-3.13C18.91 1.675 15.82 0 12.24 0 5.48 0 0 5.467 0 12.21S5.48 24.42 12.24 24.42c6.72 0 12.16-4.945 12.16-12.21 0-.74-.066-1.457-.18-2.13H12.24z" />
              </svg>
              Google
            </a>
          </div>

          <div class="text-center space-y-3">
            <p class="text-xs text-base-content/50">
              {gettext("Don't have an account?")}
              <a href="/register" class="text-primary hover:underline font-medium ml-1">
                {gettext("Sign Up")}
              </a>
            </p>

            <div class="border-t border-white/5 pt-3">
              <a
                href={home_url}
                class="text-[11px] text-base-content/40 hover:text-primary transition-colors duration-200"
              >
                ← {gettext("Back to landing page")}
              </a>
            </div>
          </div>
        </div>

        <p class="mt-8 text-center text-[10px] text-base-content/25 font-mono tracking-wider">
          ZEA THALAMUS SECURITY SERVICE
        </p>
      </div>
    </div>
  </body>
</html>
