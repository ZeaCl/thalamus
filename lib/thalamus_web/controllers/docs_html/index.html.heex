<!-- Features Overview -->
    <div class="mb-16">
      <h2 class="text-3xl font-bold text-base-content mb-6">What's Included</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="flex gap-4">
          <div class="flex-shrink-0">
            <div class="rounded-lg bg-cyan-500/10 p-2">
              <svg
                class="h-6 w-6 text-cyan-500"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
