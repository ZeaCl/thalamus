                />
              </svg>
            </div>
          </div>
          <div>
            <h3 class="font-semibold text-base-content mb-2">OAuth2 2.0 Compliant</h3>
            <p class="text-sm text-base-content/70">
              Full support for Authorization Code, Client Credentials, and Refresh Token grants with PKCE.
            </p>
          </div>
        </div>

        <div class="flex gap-4">
          <div class="flex-shrink-0">
            <div class="rounded-lg bg-cyan-500/10 p-2">
              <svg
                class="h-6 w-6 text-cyan-500"
