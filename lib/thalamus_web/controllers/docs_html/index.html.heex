                />
              </svg>
            </div>
          </div>
          <div>
            <h3 class="font-semibold text-base-content mb-2">Security First</h3>
            <p class="text-sm text-base-content/70">
              Rate limiting, audit logging, MFA support, and comprehensive security headers.
            </p>
          </div>
        </div>
      </div>
    </div>
    
