<div class="min-h-screen bg-base-100">
  <!-- Header -->
  <div class="bg-gradient-to-r from-cyan-500 to-blue-600 text-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
      <div class="flex items-center gap-3 mb-4">
        <.link navigate="/" class="text-white/80 hover:text-white text-sm flex items-center gap-1">
          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M10 19l-7-7m0 0l7-7m-7 7h18"
            />
          </svg>
          Back to Home
        </.link>
      </div>
      <h1 class="text-4xl font-bold mb-4">Thalamus Documentation</h1>
      <p class="text-xl text-white/90">
        Complete guide to integrating OAuth2 authentication with Thalamus
      </p>
    </div>
  </div>
  
<!-- Main Content -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <!-- Quick Links Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-16">
      <!-- Getting Started -->
      <.link
